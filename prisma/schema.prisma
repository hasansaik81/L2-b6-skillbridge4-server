generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// model User {
//     id        String   @id @default(uuid())
//     email     String   @unique
//     name      String?
//     createdAt DateTime @default(now())
//     updatedAt DateTime @updatedAt
// }

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum Status {
    ACTIVE
    BANNED
}

enum CategoryType {
  DAY_CARE
  NIGHT_CARE
  RESIDENTIAL
  ONLINE
}





model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         Role
  isBanned     Boolean  @default(false)
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  status       Status   @default(ACTIVE)

  tutorProfile  TutorProfiles?
  
  bookings Booking[]

 @@index([status])
  @@map("users")
 
  
  reviews Review[]
}


model TutorProfiles{
  id          String   @id @default(uuid())
  // userId     String @unique
  bio         String
  hourlyRate  Float?
  experience  Int      // years of experience
  education   String?
  avgRating   Decimal @default(0) @db.Decimal(2, 1) 
  totalReviews Int @default(0)// e.g., 4.5
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
    
    
  tutorId     String @unique
  user    User @relation(fields: [tutorId],references: [id])
   categories Category[]
  // Relations
     bookings Booking[]
    reviews Review[]
   
   
  @@map("tutorProfile")
  
  
}


model  Subject {
  id          String   @id @default(uuid())
  name        String @unique
  description String?
  createdAt   DateTime @default(now())
  

  categoryId   String
  category    Category @relation(fields: [categoryId],references: [id])

  
  
  @@map("subjects")
}

model Category {
   id            String      @id @default(uuid())
  categoryType   CategoryType
  price         Float
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tutorId      String
  tutor        TutorProfiles @relation(fields: [tutorId],references: [id])
   
    bookings Booking[]
    subjects Subject[]
  
  
  @@map("category")
 
  
}


model Booking {
  id               String   @id @default(uuid())
  studentId        String
  tutorId          String
  categoryId       String
  startDate        DateTime
  endDate          DateTime
  totalPrice       Float
  status      BookingStatus @default(PENDING)
  note        String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student     User @relation( fields: [studentId], references: [id])
  tutor       TutorProfiles @relation( fields: [tutorId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])
  review  Review?

  @@map("bookings")
  
}

model Review {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  studentId   String
  tutorId     String
  review       String
  rating      Decimal  @db.Decimal(2, 1) // e.g., 4.5
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student     User @relation( fields: [studentId], references: [id])
  tutor       TutorProfiles @relation( fields: [tutorId], references: [id],onDelete: Cascade)
  booking     Booking @relation(fields: [bookingId],references: [id],onDelete: Cascade)

@@index([studentId])
@@index([tutorId])
 @@map("reviews")
}



