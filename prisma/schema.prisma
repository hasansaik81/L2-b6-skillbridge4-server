generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}



enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum Status {
    ACTIVE
    BANNED
}

enum CategoryType {
  DAY_CARE
  NIGHT_CARE
  RESIDENTIAL
  ONLINE
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         Role
  isBanned     Boolean  @default(false)
  avatar       String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  status       Status   @default(ACTIVE)

  bookings     Booking[]
  reviews      Review[]
  tutorProfile TutorProfiles?

  @@index([status])
  @@map("users")
}
model TutorProfiles {
  id           String   @id @default(uuid())
  bio          String
  hourlyRate   Float?
  experience   Int
  education    String?

  avgRating    Decimal  @default(0) @db.Decimal(2, 1)
  totalReviews Int      @default(0)

  tutorId      String   @unique
  user         User     @relation(fields: [tutorId], references: [id])

  categories   Category[]
  bookings     Booking[]
  reviews      Review[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
   tutorSubjects TutorSubject[]

  @@map("tutor_profiles")
 
}



model Subject {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?

  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])

  createdAt    DateTime @default(now())
   tutorSubjects TutorSubject[]
    bookings Booking[]
  @@map("subjects")
 
  
}


model Category {
  id            String       @id @default(uuid())
  categoryType  CategoryType
  price         Float
  description   String?

  tutorId       String
  tutor         TutorProfiles @relation(fields: [tutorId], references: [id])

  subjects      Subject[]
  bookings      Booking[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("categories")
}

model Booking {
  id         String        @id @default(uuid())

  studentId  String
  tutorId    String
  categoryId String
 
  startDate  DateTime
  endDate    DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)
  note       String?

  student    User          @relation(fields: [studentId], references: [id])
  tutor      TutorProfiles  @relation(fields: [tutorId], references: [id])
  category   Category      @relation(fields: [categoryId], references: [id])
   subjectId  String?
  subject     Subject?    @relation(fields: [subjectId],references:[id])

  review     Review?

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("bookings")
}


model Review {
  id         String   @id @default(uuid())

  bookingId  String   @unique
  studentId  String
  tutorId    String

  rating     Decimal  @db.Decimal(2, 1)
  comment    String?

  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [studentId], references: [id])
  tutor      TutorProfiles @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
 
 @@index([studentId])
@@index([tutorId])
  @@map("reviews")
}

model TutorSubject {
  tutorId  String
  subjectId  String

  tutor   TutorProfiles @relation(fields: [tutorId],references: [id])
  subject  Subject @relation(fields: [subjectId],references: [id])

  @@id([tutorId,subjectId])
  @@map("tutor_subjects")
}


